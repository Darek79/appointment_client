orgotPasswordMain} from \"./Login/Login_forgot\";\nimport {Calendar} from \"./Calendar/Calendar\";\nimport {C} from \"./Calendar/C\";\nimport {Buttons} from \"./Homepage/ButtonGroup\";\nimport {Sidebar} from \"./Homepage/Hamburger_Sidebar\";\nimport {Card} from \"./Homepage/Card\";\nimport Overview from \"./Appointment/isOn\";\n\nfunction App() {\n  return (\n    <Router>\n      <Switch>\n        <Route\n          exact\n          path=\"/\"\n          render={(p) => <Card />}\n        />\n        <Route\n          exact\n          path=\"/company-login\"\n          render={(p) => <LoginMain />}\n        />\n        <Route\n          exact\n          path=\"/forgot-password\"\n          render={(p) => <ForgotPasswordMain />}\n        />\n        <Route\n          exact\n          path=\"/calendar-create\"\n          render={(p) => <Overview {...p} />}\n        />\n        <Route\n          exact\n          path=\"/calendar-company\"\n          render={(p) => <Calendar {...p} />}\n        />\n        <Route\n          path=\"*\"\n          render={() => <div>ERROR</div>}\n        />\n      </Switch>\n    </Router>\n  );\n}\n\nexport default App;\n","/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/reportWebVitals.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Appointment/isOn.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Appointment/AppointmentMain.js",["137","138"],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Appointment/AppointmentOverview.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/utils/customHooks.js",[],["139","140"],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Appointment/AppointmentSummary.js",["141"],"import React from 'react';\r\n\r\nexport default ({ day, fn, ref, state, ind, clName, clSub, sub }) => (\r\n  <div\r\n    className={`sum_day ${state === ind ? clName : ''} ${\r\n      sub[ind] ? clSub : ''\r\n    }`}\r\n    ref={ref}\r\n    onClick={fn}>\r\n    <p>{day}</p>\r\n  </div>\r\n);\r\n",["142","143"],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Appointment/AppointmentDay.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/svg/leftA.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/svg/rightA.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/svg/close_circel.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/utils/helperFn.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Login/Login_main.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/helpers/helpers.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/components/Image.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/components/Input.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/components/Button.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Login/Login_forgot.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/components/ErrorWrapper.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/utils/axios.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/components/ErrorCom.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Calendar/Calendar.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Calendar/C.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/TEST_COMP/test.js",["144"],"import React from \"react\";\n\nconst arr = [\n  [\n    {d: 1, v: \"APP\"},\n    {d: 1, v: \"APP\"},\n    {d: 1, v: \"APP\"},\n    {d: 1, v: \"APP\"},\n    {d: 1, v: \"APP\"},\n    {d: 1, v: \"APP\"},\n  ],\n  [\n    {d: 2, v: \"APP1\"},\n    {d: 2, v: \"APP1\"},\n    {d: 2, v: \"APP1\"},\n    {d: 2, v: \"APP1\"},\n    {d: 2, v: \"APP1\"},\n    {d: 2, v: \"APP1\"},\n  ],\n];\n\nexport const Week = () => {\n  return (\n    <section\n      style={{\n        marginLeft: \"50px\",\n        width: \"500px\",\n        height: \"200px\",\n        display: \"flex\",\n      }}>\n      {arr.map((el, i) => {\n        console.log(el[0].v);\n        return (\n          <table style={{width: \"100%\"}}>\n            <thead>\n              <tr>\n                <th scope=\"col\">{el[0].v}</th>\n              </tr>\n            </thead>\n            <tbody>\n              {el.map((el) => (\n                <tr>\n                  <td scope=\"row\">{el.v}</td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        );\n      })}\n    </section>\n  );\n};\n",["145","146"],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Redux/root_reducer.js",[],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Homepage/ButtonGroup.js",["147","148","149"],"import React, {useState, useEffect} from \"react\";\nimport isMobile from \"../helpers/helpers\";\nimport {useSpring, animated} from \"react-spring\";\nimport {makeStyles} from \"@material-ui/core/styles\";\nimport Button from \"@material-ui/core/Button\";\nimport ButtonGroup from \"@material-ui/core/ButtonGroup\";\nimport {Link} from \"react-router-dom\";\nconst useStyle = makeStyles({\n  main: {\n    background: \"#f94144\",\n    border: 0,\n    boxShadow:\n      \"0 3px 5px 2px rgba(255, 105, 135, .3)\",\n    color: \"white\",\n    height: 30,\n    width: 100,\n    padding: \"0 30px\",\n    \"&:hover\": {\n      //you want this to be the same as the backgroundColor above\n      backgroundColor: \"#f3722c\",\n    },\n  },\n  color: {\n    color: \"#fff\",\n  },\n});\n\nexport const Buttons = ({\n  linknames = [\n    \"HOME\",\n    \"GALLERY\",\n    \"PRICES\",\n    \"TEAM\",\n    \"CONTACT\",\n    \"ABOUT\",\n  ],\n}) => {\n  const classes = useStyle();\n  const [toggle, setToggle] = useState(false);\n  const [prop, set] = useSpring(() => ({\n    opacity: 1,\n    width: \"400px\",\n    height: \"400px\",\n    position: \"relative\",\n  }));\n  useEffect(() => {\n    set({opacity: toggle ? 1 : 0});\n  }, [toggle]);\n\n  const click = () => {\n    setToggle((p) => !p);\n  };\n  return (\n    <animated.section\n      className=\"homepage\"\n      style={prop}>\n      <ButtonGroup aria-label=\"outlined secondary button group\">\n        {linknames.map((btn) => (\n          <Button className={classes.main}>\n            <Link\n              className={classes.color}\n              to={`/${btn.toLowerCase()}`}>\n              {btn}\n            </Link>\n          </Button>\n        ))}\n      </ButtonGroup>\n    </animated.section>\n  );\n};\n","/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Homepage/Hamburger_Sidebar.js",["150","151"],"import React from \"react\";\nimport MenuOutlinedIcon from \"@material-ui/icons/MenuOutlined\";\nimport List from \"@material-ui/core/List\";\nimport ListItem from \"@material-ui/core/ListItem\";\nimport ListItemText from \"@material-ui/core/ListItemText\";\nimport {Link} from \"react-router-dom\";\nimport {makeStyles} from \"@material-ui/core/styles\";\n\nconst sidebar = makeStyles({\n  section: {\n    width: 200,\n    background: \"f8961e\",\n  },\n  list: {\n    background: \"#5e6472\",\n  },\n});\nexport const Sidebar = ({\n  items = [\n    \"HOME\",\n    \"GALLERY\",\n    \"PRICES\",\n    \"TEAM\",\n    \"CONTACT\",\n    \"ABOUT\",\n  ],\n}) => {\n  const classes = sidebar();\n  return (\n    <section className={classes.section}>\n      {/* <MenuOutlinedIcon style={{fontSize: 50}} /> */}\n      <List className={classes.list}>\n        {items.map((item) => (\n          <ListItem button>\n            <Link to={`/${item.toLowerCase()}`}>\n              {item}\n            </Link>\n          </ListItem>\n        ))}\n      </List>\n    </section>\n  );\n};\n","/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Homepage/Header/Header.js",["152","153","154","155"],"/media/darek/Seagate Expansion Drive/WebstormProjects/calender_module_client/src/Homepage/Card.js",["156","157","158","159","160"],{"ruleId":"161","replacedBy":"162"},{"ruleId":"163","replacedBy":"164"},{"ruleId":"165","severity":1,"message":"166","line":11,"column":9,"nodeType":"167","messageId":"168","endLine":11,"endColumn":10},{"ruleId":"165","severity":1,"message":"169","line":12,"column":9,"nodeType":"167","messageId":"168","endLine":12,"endColumn":16},{"ruleId":"165","severity":1,"message":"170","line":13,"column":9,"nodeType":"167","messageId":"168","endLine":13,"endColumn":16},{"ruleId":"165","severity":1,"message":"171","line":3,"column":3,"nodeType":"167","messageId":"168","endLine":3,"endColumn":9},{"ruleId":"172","severity":1,"message":"173","line":33,"column":3,"nodeType":"167","endLine":33,"endColumn":12,"suggestions":"174"},{"ruleId":"161","replacedBy":"175"},{"ruleId":"163","replacedBy":"176"},{"ruleId":"177","severity":1,"message":"178","line":3,"column":1,"nodeType":"179","endLine":12,"endColumn":3},{"ruleId":"161","replacedBy":"180"},{"ruleId":"163","replacedBy":"181"},{"ruleId":"182","severity":1,"message":"183","line":43,"column":23,"nodeType":"184","endLine":43,"endColumn":34},{"ruleId":"161","replacedBy":"185"},{"ruleId":"163","replacedBy":"186"},{"ruleId":"165","severity":1,"message":"187","line":2,"column":8,"nodeType":"167","messageId":"168","endLine":2,"endColumn":16},{"ruleId":"172","severity":1,"message":"188","line":48,"column":6,"nodeType":"189","endLine":48,"endColumn":14,"suggestions":"190"},{"ru