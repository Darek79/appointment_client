"line":29,"column":18,"nodeType":"141","messageId":"142","endLine":29,"endColumn":27},{"ruleId":"139","severity":1,"message":"160","line":1,"column":16,"nodeType":"141","messageId":"142","endLine":1,"endColumn":25},{"ruleId":"139","severity":1,"message":"161","line":7,"column":9,"nodeType":"141","messageId":"142","endLine":7,"endColumn":16},{"ruleId":"139","severity":1,"message":"162","line":13,"column":9,"nodeType":"141","messageId":"142","endLine":13,"endColumn":22},"no-native-reassign",["163"],"no-negated-in-lhs",["164"],"import/no-anonymous-default-export","Assign arrow function to a variable before exporting as module default","ExportDefaultDeclaration","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'history.location.state.email'. Either include it or remove the dependency array.","ArrayExpression",["165"],"no-unused-vars","'useRef' is defined but never used.","Identifier","unusedVar","React Hook useEffect contains a call to 'setMon'. Without a list of dependencies, this can lead to an infinite chain of updates. To fix this, pass [mon, tue, wed, thu, fri, sat] as a second argument to the useEffect Hook.",["166"],"'weekdays' is assigned a value but never used.",["163"],["164"],"React Hook useEffect has a missing dependency: 'dayToCheck'. Either include it or remove the dependency array.",["167"],"React Hook useEffect has missing dependencies: 'dayM' and 'dayToCheck'. Either include them or remove the dependency array.",["168"],"'saveDates' is assigned a value but never used.",["163"],["164"],"'startEndTime' is defined but never used.","'v4' is defined but never used.","'useContext' is defined but never used.","'history' is assigned a value but never used.","'setSubmit' is assigned a value but never used.","'useEffect' is defined but never used.","'NavLink' is defined but never used.","'inputPassword' is assigned a value but never used.","no-global-assign","no-unsafe-negation",{"desc":"169","fix":"170"},{"desc":"171","fix":"172"},{"desc":"173","fix":"174"},{"desc":"175","fix":"176"},"Update the dependencies array to be: [history.location.state.email, saved]",{"range":"177","text":"178"},"Add dependencies array: [mon, tue, wed, thu, fri, sat]",{"range":"179","text":"180"},"Update the dependencies array to be: [active, dayToCheck, skip]",{"range":"181","text":"182"},"Update the dependencies array to be: [dayM, dayToCheck, toSave]",{"range":"183","text":"184"},[1074,1081],"[history.location.state.email, saved]",[2158,2158],", [mon, tue, wed, thu, fri, sat]",[1132,1146],"[active, dayToCheck, skip]",[1300,1308],"[dayM, dayToCheck, toSave]"]